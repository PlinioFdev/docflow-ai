# Django settings
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC

# Database settings
POSTGRES_DB=docflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
